{
  "name": "3r-laundry-backend",
  "version": "1.0.0",
  "description": "Backend for 3R Laundry Service",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build:web": "cd ../apps/student-web && npm install --legacy-peer-deps && npm run build:web",
    "build": "npm run build:web && echo 'Copying student web build...' && mkdir -p public/user && cp -r ../apps/student-web/web-build/* public/user/ || echo 'Windows copy failed, skipping for now'",
    "dev": "nodemon server.js",
    "test": "jest",
    "e2e:user": "node scripts/e2e_user_boot_web.js",
    "verify-db": "node scripts/verify-db.js"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "eventsource": "^4.1.0",
    "express": "^4.18.2",
    "firebase-admin": "^13.7.0",
    "form-data": "^4.0.5",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.0.2",
    "ngrok": "^5.0.0-beta.2",
    "nodemailer": "^6.10.1",
    "pg": "^8.11.5",
    "pg-hstore": "^2.3.4",
    "resend": "^6.9.3",
    "sequelize": "^6.29.0",
    "socket.io": "^4.8.3",
    "sqlite3": "^5.1.4"
  },
  "devDependencies": {
    "jest": "^29.6.0",
    "nodemon": "^2.0.21",
    "puppeteer": "^22.0.0",
    "supertest": "^6.3.3"
  }
}
